<ui:FluentWindow x:Class="LudusaviWrap.BrowseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:LudusaviWrap"
        Title="Browse Games"
        Width="960"
        Height="640"
        MinWidth="720"
        MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Browse Games" ShowMaximize="True" Grid.Row="0"/>

        <!-- Search bar -->
        <Grid Grid.Row="1" Margin="16,10,16,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox x:Name="SearchBox"
                        PlaceholderText="Search games..."
                        Grid.Column="0"
                        TextChanged="SearchBox_TextChanged"/>
            <ui:Button x:Name="RefreshButton"
                       Content="Refresh"
                       Appearance="Secondary"
                       Grid.Column="2"
                       Click="Refresh_Click"/>
        </Grid>

        <!-- Status row -->
        <Grid Grid.Row="2" Margin="16,0,16,6" Height="20">
            <StackPanel x:Name="LoadingPanel" Orientation="Horizontal" Visibility="Collapsed">
                <ui:ProgressRing IsIndeterminate="True"
                                 Width="14" Height="14"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"/>
                <TextBlock x:Name="LoadingText"
                           Text="Loading sources..."
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"/>
            </StackPanel>
            <TextBlock x:Name="ResultCountText"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       FontSize="12"
                       Visibility="Collapsed"/>
        </Grid>

        <!-- Results -->
        <ui:ListView x:Name="ResultsView"
                     Grid.Row="3"
                     Margin="16,0,16,0"
                     Background="Transparent"
                     BorderThickness="0"
                     SelectionChanged="ResultsView_SelectionChanged"
                     MouseDoubleClick="ResultsView_MouseDoubleClick"
                     GridViewColumnHeader.Click="ColumnHeader_Click"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ui:ListView.View>
                <ui:GridView>
                    <ui:GridViewColumn Header="Title" Width="390">
                        <ui:GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Title}"/>
                            </DataTemplate>
                        </ui:GridViewColumn.CellTemplate>
                    </ui:GridViewColumn>
                    <ui:GridViewColumn Header="Size" Width="95" DisplayMemberBinding="{Binding FileSize}"/>
                    <ui:GridViewColumn Header="Date" Width="100" DisplayMemberBinding="{Binding UploadDateFormatted}"/>
                    <ui:GridViewColumn Header="Source" Width="130" DisplayMemberBinding="{Binding SourceName}"/>
                </ui:GridView>
            </ui:ListView.View>
        </ui:ListView>

        <!-- Action row -->
        <Grid Grid.Row="4" Margin="16,8,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SelectionInfoText"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       FontSize="12"
                       Grid.Column="0"/>
            <ui:Button Content="Cancel"
                       Appearance="Secondary"
                       Width="80"
                       Grid.Column="1"
                       Click="Cancel_Click"/>
            <ui:Button x:Name="DownloadButton"
                       Content="Download"
                       Appearance="Primary"
                       Width="100"
                       Grid.Column="3"
                       IsEnabled="False"
                       Click="Download_Click"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
