<ui:FluentWindow x:Class="LudusaviWrap.DownloadLocationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:LudusaviWrap"
        Title="Choose Download Folder"
        Width="500"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Choose Download Folder"
                     ShowMaximize="False"
                     Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Game Name Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Download Game"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="GameNameLabel"
                           Text="Game Name"
                           FontSize="20"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Already Installed warning -->
            <Border x:Name="AlreadyInstalledBanner"
                    Grid.Row="1"
                    Background="#33FF5F5F"
                    CornerRadius="4"
                    Padding="12,8"
                    Margin="0,0,0,16"
                    Visibility="Collapsed">
                <TextBlock x:Name="AlreadyInstalledLabel"
                           Foreground="#FFFF5F5F"
                           TextWrapping="Wrap"
                           FontSize="12"/>
            </Border>

            <!-- Destination Card -->
            <ui:Card Grid.Row="2" x:Name="DestCard" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Install Directory"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    
                    <Grid x:Name="DestFieldsGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="DestFolderBox"
                                    IsReadOnly="True"
                                    PlaceholderText="Select destination folder..."
                                    Margin="0,0,8,0"
                                    Grid.Column="0"/>
                        <ui:Button Content="Browse"
                                   Appearance="Secondary"
                                   Click="BrowseDest_Click"
                                   Grid.Column="1"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Action buttons -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button x:Name="DownloadButton"
                           Grid.Column="0"
                           Content="Download"
                           Appearance="Primary"
                           Height="40"
                           HorizontalAlignment="Stretch"
                           Click="Download_Click"/>
                <ui:Button x:Name="CancelButton"
                           Grid.Column="2"
                           Content="Cancel"
                           Appearance="Secondary"
                           Height="40"
                           Click="Cancel_Click"/>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
