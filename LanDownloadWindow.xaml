<ui:FluentWindow x:Class="LudusaviWrap.LanDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:LudusaviWrap"
        Title="Download from LAN"
        Width="580"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Download from LAN"
                     ShowMaximize="False"
                     Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Discovery / peer selection panel -->
            <ui:Card Grid.Row="0" Margin="0,0,0,12" x:Name="DiscoveryCard">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Available peers"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Grid.Column="0"/>
                        <ui:Button x:Name="RescanButton"
                                   Content="Rescan"
                                   Appearance="Secondary"
                                   Click="Rescan_Click"
                                   Grid.Column="1"/>
                    </Grid>

                    <!-- Scanning indicator -->
                    <StackPanel x:Name="ScanningPanel" Orientation="Horizontal" Margin="0,0,0,4">
                        <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Scanning network..." VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Peer tree -->
                    <TreeView x:Name="PeerTree"
                              BorderThickness="0"
                              Background="Transparent"
                              MaxHeight="200"
                              Visibility="Collapsed"
                              SelectedItemChanged="PeerTree_SelectedItemChanged"/>

                    <!-- No peers message -->
                    <TextBlock x:Name="NoPeersLabel"
                               Text="No peers found on this network."
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontStyle="Italic"
                               Visibility="Collapsed"/>
                </StackPanel>
            </ui:Card>

            <!-- Destination + conflict card -->
            <ui:Card Grid.Row="1" Margin="0,0,0,12" x:Name="DestCard" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Destination"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <!-- Already installed warning -->
                    <Border x:Name="AlreadyInstalledBanner"
                            Background="#33FF5F5F"
                            CornerRadius="4"
                            Padding="10,6"
                            Margin="0,0,0,8"
                            Visibility="Collapsed">
                        <TextBlock x:Name="AlreadyInstalledLabel"
                                   Foreground="#FFFF5F5F"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Grid x:Name="DestFieldsGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="DestFolderBox"
                                    IsReadOnly="True"
                                    PlaceholderText="Select destination folder..."
                                    Margin="0,0,8,0"
                                    Grid.Column="0"/>
                        <ui:Button Content="Browse"
                                   Appearance="Secondary"
                                   Click="BrowseDest_Click"
                                   Grid.Column="1"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Action buttons -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button x:Name="DownloadButton"
                           Grid.Column="0"
                           Content="Download"
                           Appearance="Primary"
                           Height="40"
                           HorizontalAlignment="Stretch"
                           IsEnabled="False"
                           Click="Download_Click"/>
                <ui:Button x:Name="CloseButton"
                           Grid.Column="2"
                           Content="Close"
                           Appearance="Secondary"
                           Height="40"
                           Click="Close_Click"/>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
