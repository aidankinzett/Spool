<ui:FluentWindow x:Class="LudusaviWrap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:LudusaviWrap"
        Title="Ludusavi Wrap"
        Width="940"
        MinWidth="700"
        MinHeight="500"
        Height="620"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:StringToImageConverter x:Key="StringToImageConverter"/>
        <local:SyncStatusToBrushConverter x:Key="SyncStatusToBrushConverter"/>
        <local:SyncStatusToLabelConverter x:Key="SyncStatusToLabelConverter"/>
        <local:SyncStatusToVisibilityConverter x:Key="SyncStatusToVisibilityConverter"/>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>

        <ContextMenu x:Key="GameCardContextMenu" x:Shared="False">
            <MenuItem Header="Generate for Armoury Crate" Click="ContextGenerateAC_Click"/>
            <MenuItem Header="Add to Steam" Click="ContextAddToSteam_Click"/>
            <Separator/>
            <MenuItem Header="Open Game Folder" Click="ContextOpenFolder_Click"/>
            <MenuItem Header="Set Game Folder (LAN Share)" Click="ContextSetFolder_Click"/>
            <Separator/>
            <MenuItem Header="Remove from Library" Click="ContextRemove_Click"/>
        </ContextMenu>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Ludusavi Wrap"
                     ShowMaximize="True"
                     Grid.Row="0"/>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="24,8,24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="My Library"
                       FontSize="20"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Grid.Column="0"/>
            <!-- WiFi Status Panel -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                <ui:ProgressRing IsIndeterminate="True"
                                 Width="16"
                                 Height="16"
                                 Margin="0,0,8,0"
                                 Visibility="{Binding IsLanScanning, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <ui:SymbolIcon Symbol="Wifi224"
                               Margin="0,0,6,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <TextBlock FontSize="13"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <Run Text="{Binding LanPeersCount, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Mode=OneWay}"/>
                    <Run Text=" peers"/>
                </TextBlock>
            </StackPanel>
            <ui:Button x:Name="BrowseButton"
                       Grid.Column="3"
                       Content="Browse"
                       Icon="{ui:SymbolIcon Symbol=Search24}"
                       Appearance="Secondary"
                       Click="Browse_Click"/>
            <ui:Button x:Name="AddGameButton"
                       Grid.Column="5"
                       Content="Add Game"
                       Appearance="Primary"
                       Click="AddGame_Click"/>
            <ui:Button x:Name="SettingsButton"
                       Grid.Column="7"
                       Content="Settings"
                       Appearance="Secondary"
                       Click="Settings_Click"/>
        </Grid>

        <!-- Separator -->
        <Separator Grid.Row="2" Margin="0"/>

        <!-- Content area -->
        <Grid Grid.Row="3">

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="No games yet"
                           FontSize="22"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="Click Add Game to add your first game."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,24"/>
                <ui:Button Content="Add Game"
                           Appearance="Primary"
                           HorizontalAlignment="Center"
                           Click="AddGame_Click"/>
            </StackPanel>

            <!-- Library scroll area -->
            <ScrollViewer x:Name="LibraryScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,12,16,16"
                          Visibility="Collapsed">
                <ItemsControl x:Name="GamesGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemWidth="192" ItemHeight="392"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:GameEntry}">
                            <ui:Card Width="180" Height="380" Margin="6" Padding="0">
                                <ui:Card.Style>
                                    <Style TargetType="ui:Card" BasedOn="{StaticResource {x:Type ui:Card}}">
                                        <Setter Property="ContextMenu" Value="{StaticResource GameCardContextMenu}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLanCard}" Value="True">
                                                <Setter Property="ContextMenu" Value="{x:Null}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Card.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="270"/>
                                        <RowDefinition Height="110"/>
                                    </Grid.RowDefinitions>

                                    <!-- Cover image -->
                                    <Border Grid.Row="0"
                                            ClipToBounds="True"
                                            CornerRadius="4,4,0,0"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                                        <Image Source="{Binding CoverImagePath, Converter={StaticResource StringToImageConverter}}"
                                               Stretch="Uniform"/>
                                    </Border>

                                    <!-- Info area -->
                                    <Grid Grid.Row="1" Margin="8,6,8,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Row="0" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding GameName}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding GameName}"
                                                       Height="34"
                                                       Margin="0,0,0,2"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,4"
                                                        Visibility="{Binding SyncStatus, Converter={StaticResource SyncStatusToVisibilityConverter}}"
                                                        ToolTip="{Binding SyncStatus, Converter={StaticResource SyncStatusToLabelConverter}}">
                                                <Ellipse Width="6" Height="6"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,4,0"
                                                         Fill="{Binding SyncStatus, Converter={StaticResource SyncStatusToBrushConverter}}"/>
                                                <TextBlock Text="{Binding SyncStatus, Converter={StaticResource SyncStatusToLabelConverter}}"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding SyncStatus, Converter={StaticResource SyncStatusToBrushConverter}}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Grid Grid.Row="1" VerticalAlignment="Bottom">
                                            <ui:Button Content="Play"
                                                       Icon="{ui:SymbolIcon Symbol=Play24}"
                                                       Appearance="Primary"
                                                       HorizontalAlignment="Stretch"
                                                       Click="Play_Click"
                                                       Visibility="{Binding IsLanCard, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                            <ui:Button Content="Download"
                                                       Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"
                                                       Appearance="Secondary"
                                                       HorizontalAlignment="Stretch"
                                                       Click="DownloadCard_Click"
                                                       Visibility="{Binding IsLanCard, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>

        <!-- Separator before upload bar (visible only when upload bar is visible) -->
        <Separator x:Name="UploadSeparator" Grid.Row="4" Visibility="Collapsed" Margin="0"/>

        <!-- Upload status bar -->
        <Border x:Name="UploadBarGrid" Grid.Row="5" Background="{DynamicResource CardBackgroundFillBrushDefault}" Padding="24,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="UploadTitleText"
                                   Text="Uploading Game..."
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Grid.Column="0"/>
                        <TextBlock x:Name="UploadStatusText"
                                   Text="0 KB/s - 0 MB of 0 MB"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   Grid.Column="1"/>
                    </Grid>
                    <ProgressBar x:Name="UploadProgressBar"
                                 Height="8"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"/>
                </StackPanel>

                <ui:Button x:Name="CancelUploadButton"
                           Grid.Column="1"
                           Content="Cancel"
                           Appearance="Danger"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Click="CancelUpload_Click"/>
            </Grid>
        </Border>

        <!-- Separator before download bar (visible only when download bar is visible) -->
        <Separator x:Name="DownloadSeparator" Grid.Row="6" Visibility="Collapsed" Margin="0"/>

        <!-- Download status bar -->
        <Border x:Name="DownloadBarGrid" Grid.Row="7" Background="{DynamicResource CardBackgroundFillBrushDefault}" Padding="24,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <TextBlock x:Name="DownloadTitleText"
                                       Text="Preparing..."
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                            <TextBlock x:Name="DownloadCountText"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="8,1,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Bottom">
                            <TextBlock x:Name="DownloadSpeedText"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,8,0"/>
                            <TextBlock x:Name="DownloadBytesText"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <ProgressBar x:Name="DownloadProgressBar"
                                 Height="8"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"/>
                </StackPanel>

                <ui:Button x:Name="CancelDownloadButton"
                           Grid.Column="1"
                           Content="Cancel"
                           Appearance="Danger"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Click="CancelDownload_Click"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
