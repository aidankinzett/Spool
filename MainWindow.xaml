<Window x:Class="LudusaviWrap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ludusavi Wrap" 
        Width="660" 
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="{StaticResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Separator -->
            <RowDefinition Height="Auto"/> <!-- Form Rows -->
            <RowDefinition Height="Auto"/> <!-- Generate Button -->
            <RowDefinition Height="Auto"/> <!-- Status Label -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Ludusavi Wrap" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Generate a save-managed launcher .exe for Armoury Crate" 
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"
                           Margin="0,2,0,0"/>
            </StackPanel>
            <Button Content="Settings" 
                    Width="80" 
                    Style="{StaticResource SecondaryButton}" 
                    Click="Settings_Click"
                    Grid.Column="1"
                    VerticalAlignment="Top"/>
        </Grid>

        <!-- Separator -->
        <Border BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,1,0,0" 
                Margin="0,16,0,16" 
                Grid.Row="1"/>

        <!-- Form Rows -->
        <StackPanel Grid.Row="2">
            <!-- Row 1: Executable -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Executable" 
                           Foreground="{StaticResource TextBrush}" 
                           VerticalAlignment="Center"
                           Grid.Column="0"/>
                <TextBox x:Name="ExePathTextBox" 
                         IsReadOnly="True" 
                         Tag="Browse to a game executable..."
                         Margin="0,0,8,0"
                         Grid.Column="1"/>
                <Button Content="Browse" 
                        Width="80" 
                        Style="{StaticResource SecondaryButton}" 
                        Click="BrowseExe_Click"
                        Grid.Column="2"/>
            </Grid>

            <!-- Row 2: Game Name -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Game Name" 
                           Foreground="{StaticResource TextBrush}" 
                           VerticalAlignment="Center"
                           Grid.Column="0"/>
                <TextBox x:Name="GameNameTextBox" 
                         Tag="Enter or search for game name..."
                         GotFocus="TextBox_GotFocus"
                         Margin="0,0,8,0"
                         Grid.Column="1"/>
                <Button x:Name="SearchButton" 
                        Content="Search" 
                        Width="80" 
                        Style="{StaticResource SecondaryButton}" 
                        Click="Search_Click"
                        Grid.Column="2"/>
            </Grid>

            <!-- Autocomplete Results Box -->
            <Grid Margin="110,0,0,12">
                <Border x:Name="ResultsBorder" 
                        Style="{StaticResource CardFrame}" 
                        Padding="2"
                        MaxHeight="120"
                        Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="ResultsListBox" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 Foreground="{StaticResource TextBrush}"
                                 SelectionChanged="ResultsListBox_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </ScrollViewer>
                </Border>
            </Grid>
        </StackPanel>

        <!-- Generate Button -->
        <Button x:Name="GenerateButton" 
                Content="Generate Wrapper" 
                Height="40" 
                FontSize="14" 
                Click="Generate_Click"
                Margin="0,8,0,16"
                Grid.Row="3"/>

        <!-- Status Label -->
        <TextBlock x:Name="StatusLabel" 
                   Text="" 
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center" 
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"
                   Visibility="Collapsed"
                   Grid.Row="4"/>
    </Grid>
</Window>
