<ui:FluentWindow x:Class="LudusaviWrap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:LudusaviWrap"
        Title="Spool"
        Width="1260" Height="820"
        MinWidth="900" MinHeight="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainWindowResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Title bar ═══ -->
        <ui:TitleBar Grid.Row="0" ShowMaximize="True" Height="40" Title=" ">
            <ui:TitleBar.Header>
                <!-- Branding -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="-16,0,0,0">
                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                        <Canvas Width="64" Height="64">
                            <Rectangle Canvas.Left="8" Canvas.Top="16" Width="48" Height="32"
                                       RadiusX="4" RadiusY="4"
                                       Stroke="White" StrokeThickness="3.5" Fill="Transparent"/>
                            <Ellipse Canvas.Left="18" Canvas.Top="24" Width="8" Height="8" Fill="White"/>
                            <Ellipse Canvas.Left="38" Canvas.Top="24" Width="8" Height="8" Fill="White"/>
                            <Line X1="14" Y1="42" X2="50" Y2="42"
                                  Stroke="White" StrokeThickness="3"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Spool" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="7,0,0,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </ui:TitleBar.Header>
            <ui:TitleBar.TrailingContent>
                <!-- Settings button only — window controls follow automatically -->
                <Button x:Name="SettingsButton" Click="Settings_Click"
                        Width="46" Height="32" VerticalAlignment="Center" Cursor="Hand" ToolTip="Settings">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <ui:SymbolIcon Symbol="Settings20" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </Button>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <!-- LAN peers pill — centred in the window title bar -->
        <Border Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                CornerRadius="10" Padding="10,3"
                Background="#0AFFFFFF" BorderBrush="#0FFFFFFF" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <ui:ProgressRing IsIndeterminate="True" Width="10" Height="10"
                                 Margin="0,0,6,0"
                                 Visibility="{Binding IsLanScanning, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Converter={StaticResource BoolToVis}}"/>
                <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0"
                         Visibility="{Binding IsLanScanning, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Converter={StaticResource InvBoolToVis}}">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#4D4D4D"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LanPeersCount, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}}" Value="0">
                                    <Setter Property="Fill" Value="#4D4D4D"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <ui:SymbolIcon Symbol="Wifi224" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,5,0"/>
                <TextBlock FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <Run Text="{Binding LanPeersCount, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Mode=OneWay}"/>
                    <Run Text=" peers on LAN"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══ Two-pane layout ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Sidebar ── -->
            <Grid Grid.Column="0" Background="#2E000000">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search -->
                <Grid Grid.Row="0" Margin="12,14,12,0">
                    <ui:TextBox x:Name="SearchBox"
                                PlaceholderText="Search library…"
                                FontSize="13"
                                TextChanged="SearchBox_TextChanged"/>
                </Grid>

                <!-- Filter pills + sort -->
                <Grid Grid.Row="1" Margin="12,8,12,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ToggleButton x:Name="FilterAll" Grid.Column="0" Content="All"
                                  Style="{StaticResource FilterChip}" IsChecked="True"
                                  Margin="0,0,4,0" Click="FilterChip_Click" Tag="all"/>
                    <ToggleButton x:Name="FilterRecent" Grid.Column="1" Content="Recent"
                                  Style="{StaticResource FilterChip}"
                                  Margin="0,0,4,0" Click="FilterChip_Click" Tag="recent"/>
                    <ToggleButton x:Name="FilterShared" Grid.Column="2" Content="On LAN"
                                  Style="{StaticResource FilterChip}"
                                  Margin="0,0,4,0" Click="FilterChip_Click" Tag="shared"/>
                    <ToggleButton x:Name="FilterUnplayed" Grid.Column="3" Content="Unplayed"
                                  Style="{StaticResource FilterChip}"
                                  Click="FilterChip_Click" Tag="unplayed"/>
                    <Button x:Name="SortButton" Grid.Column="5"
                            Width="30" Height="24" Cursor="Hand" ToolTip="Sort"
                            Click="SortButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        BorderBrush="#14FFFFFF" BorderThickness="1" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#0FFFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <ui:SymbolIcon Symbol="ArrowSort24" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Button>
                    <Popup x:Name="SortPopup" PlacementTarget="{Binding ElementName=SortButton}"
                           Placement="Bottom" StaysOpen="False">
                        <Border Background="#2C2C2C" BorderBrush="#1AFFFFFF" BorderThickness="1"
                                CornerRadius="6" Padding="4" MinWidth="180">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <StackPanel>
                                <Button Content="Recently played" Tag="recent"   Style="{StaticResource SortMenuItem}" Click="SortOption_Click"/>
                                <Button Content="Name (A–Z)"       Tag="name"     Style="{StaticResource SortMenuItem}" Click="SortOption_Click"/>
                                <Button Content="Date added"        Tag="added"    Style="{StaticResource SortMenuItem}" Click="SortOption_Click"/>
                                <Button Content="Playtime"          Tag="playtime" Style="{StaticResource SortMenuItem}" Click="SortOption_Click"/>
                                <Button Content="Install size"      Tag="size"     Style="{StaticResource SortMenuItem}" Click="SortOption_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Game list -->
                <Grid Grid.Row="2">
                    <ListBox x:Name="GameListBox"
                             ItemContainerStyle="{StaticResource GameRowItem}"
                             SelectionChanged="GameListBox_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Background="Transparent" BorderThickness="0"
                             Padding="8,0,8,12"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:GameEntry}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Cover thumbnail 30x43 -->
                                    <Grid Grid.Column="0" Width="30" Height="43" Margin="0,0,10,0">
                                        <Border CornerRadius="3" Background="#2A3A4A"
                                                BorderBrush="#10FFFFFF" BorderThickness="1">
                                            <TextBlock Text="{Binding GameName, Converter={StaticResource InitialsConv}}"
                                                       FontSize="9" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                       Margin="2,0,2,2"/>
                                        </Border>
                                        <Image Source="{Binding CoverImagePath, Converter={StaticResource StringToImageConverter}}"
                                               Stretch="UniformToFill">
                                            <Image.Clip>
                                                <RectangleGeometry RadiusX="3" RadiusY="3" Rect="0,0,30,43"/>
                                            </Image.Clip>
                                        </Image>
                                    </Grid>
                                    <!-- Name + meta -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding GameName}"
                                                   FontSize="13" Foreground="White"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <ui:SymbolIcon Symbol="Clock24" FontSize="10"
                                                           Foreground="#80FFFFFF" VerticalAlignment="Center"
                                                           Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding LastPlayedAt, Converter={StaticResource RelDate}}"
                                                       FontSize="11" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                            <ui:SymbolIcon Symbol="Wifi224" FontSize="12"
                                                           Foreground="#7EE2A4" VerticalAlignment="Center"
                                                           Margin="6,0,0,0"
                                                           Visibility="{Binding LanShared, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- No results -->
                    <TextBlock Text="No games match."
                               FontSize="12" Foreground="#73FFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasNoFilteredGames, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <!-- Footer -->
                <StackPanel Grid.Row="3" Margin="12,0,12,12">
                    <Rectangle Height="1" Fill="#0DFFFFFF" Margin="0,0,0,8"/>
                    <ui:Button x:Name="AddGameButton"
                               Content="Add Game"
                               Icon="{ui:SymbolIcon Symbol=Add24}"
                               Appearance="Primary"
                               HorizontalAlignment="Stretch"
                               Margin="0,0,0,6"
                               Click="AddGame_Click"/>
                    <ui:Button x:Name="BrowseButton"
                               Content="Browse Games"
                               Icon="{ui:SymbolIcon Symbol=Search24}"
                               Appearance="Secondary"
                               HorizontalAlignment="Stretch"
                               Margin="0,0,0,8"
                               Click="Browse_Click"/>
                    <TextBlock HorizontalAlignment="Center" FontSize="11" Foreground="#66FFFFFF">
                        <Run Text="{Binding LibraryCount, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Mode=OneWay}"/>
                        <Run Text=" games in library"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- Pane separator -->
            <Rectangle Grid.Column="1" Fill="#0DFFFFFF"/>

            <!-- ── RIGHT: Detail / empty pane ── -->
            <Grid Grid.Column="2">

                <!-- Empty state -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SelectedGame, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Converter={StaticResource InvNullToVis}}">
                    <StackPanel Margin="32,32,32,40">
                        <TextBlock Text="Your Library" FontSize="28" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Pick a game on the left, or add a new one."
                                   FontSize="13" Foreground="#8CFFFFFF" Margin="0,0,0,28"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource DetailCard}" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="GAMES" FontSize="10" Foreground="#80FFFFFF"
                                               FontWeight="Medium" Margin="0,0,0,6"/>
                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="White"
                                               Text="{Binding LibraryCount, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource DetailCard}" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="TOTAL PLAYTIME" FontSize="10" Foreground="#80FFFFFF"
                                               FontWeight="Medium" Margin="0,0,0,6"/>
                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="White"
                                               Text="{Binding TotalPlaytime, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Style="{StaticResource DetailCard}" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="SAVE BACKUPS" FontSize="10" Foreground="#80FFFFFF"
                                               FontWeight="Medium" Margin="0,0,0,6"/>
                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="White"
                                               Text="{Binding TotalBackups, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="6" Style="{StaticResource DetailCard}" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="ON DISK" FontSize="10" Foreground="#80FFFFFF"
                                               FontWeight="Medium" Margin="0,0,0,6"/>
                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="White"
                                               Text="{Binding TotalInstallSize, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Game detail pane -->
                <Grid x:Name="DetailPane"
                      DataContext="{Binding SelectedGame, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}}"
                      Visibility="{Binding SelectedGame, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Converter={StaticResource NullToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="300"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ClipToBounds="True">
                        <Rectangle>
                            <Rectangle.Fill>
                                <Binding Path="CoverImagePath" Converter="{StaticResource CoverToBackgroundBrushConverter}"/>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Image Source="{Binding HeroImagePath, Converter={StaticResource StringToImageConverter}}"
                               Stretch="UniformToFill" Opacity="0.35"/>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0.3"/>
                                    <GradientStop Color="#CC000000" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Bottom-left: cover + title -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="32,0,0,28">
                            <!-- Cover card -->
                            <Grid Width="96" Height="139">
                                <Border CornerRadius="4" Background="#2A3A4A"
                                        BorderBrush="#1AFFFFFF" BorderThickness="1">
                                    <TextBlock Text="{Binding GameName, Converter={StaticResource InitialsConv}}"
                                               FontSize="22" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                               Margin="4,0,4,4"/>
                                </Border>
                                <Image Source="{Binding CoverImagePath, Converter={StaticResource StringToImageConverter}}"
                                       Stretch="UniformToFill">
                                    <Image.Clip>
                                        <RectangleGeometry RadiusX="4" RadiusY="4" Rect="0,0,96,139"/>
                                    </Image.Clip>
                                </Image>
                            </Grid>
                            <!-- Title + meta -->
                            <StackPanel VerticalAlignment="Bottom" Margin="20,0,0,4" MaxWidth="520">
                                <TextBlock Text="{Binding GameName}"
                                           FontSize="32" FontWeight="Bold" Foreground="White"
                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding Developer}"
                                               FontSize="12" Foreground="#C8FFFFFF" VerticalAlignment="Center"/>
                                    <TextBlock Text=" · " FontSize="12" Foreground="#66FFFFFF" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ReleaseDate, Converter={StaticResource YearConv}}"
                                               FontSize="12" Foreground="#C8FFFFFF" VerticalAlignment="Center"/>
                                    <TextBlock Text=" · " FontSize="12" Foreground="#66FFFFFF" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Genres, Converter={StaticResource GenreListConv}}"
                                               FontSize="11" Foreground="#D8FFFFFF" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Play / Download button -->
                        <Button x:Name="HeroPlayBtn" Style="{StaticResource PlayBtn}"
                                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                Margin="0,0,28,28" Click="Play_Click"
                                Visibility="{Binding IsLanCard, Converter={StaticResource InvBoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Play24" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Play" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DownloadBtn}"
                                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                Margin="0,0,28,28" Click="DetailDownload_Click"
                                Visibility="{Binding IsLanCard, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Download" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Scrollable detail body -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- Stats strip -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Padding="32,18,16,18"
                                        BorderBrush="#0AFFFFFF" BorderThickness="0,0,1,1">
                                    <StackPanel>
                                        <TextBlock Text="LAST PLAYED" FontSize="10" FontWeight="Medium"
                                                   Foreground="#80FFFFFF" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding LastPlayedAt, Converter={StaticResource RelDate}}"
                                                   FontSize="17" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="{Binding LastPlayedAt, Converter={StaticResource AbsDate}}"
                                                   FontSize="11" Foreground="#73FFFFFF" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Padding="16,18"
                                        BorderBrush="#0AFFFFFF" BorderThickness="1,0,1,1">
                                    <StackPanel>
                                        <TextBlock Text="PLAYTIME" FontSize="10" FontWeight="Medium"
                                                   Foreground="#80FFFFFF" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding PlaytimeMinutes, Converter={StaticResource PlaytimeConv}}"
                                                   FontSize="17" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Padding="16,18"
                                        BorderBrush="#0AFFFFFF" BorderThickness="0,0,1,1">
                                    <StackPanel>
                                        <TextBlock Text="INSTALL SIZE" FontSize="10" FontWeight="Medium"
                                                   Foreground="#80FFFFFF" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding InstallSizeMb, Converter={StaticResource SizeMbConv}}"
                                                   FontSize="17" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Padding="16,18"
                                        BorderBrush="#0AFFFFFF" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="LAN SHARE" FontSize="10" FontWeight="Medium"
                                                   Foreground="#80FFFFFF" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="White">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Local only"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LanShared}" Value="True">
                                                            <Setter Property="Text" Value="Shared"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Action toolbar -->
                            <Border BorderBrush="#0AFFFFFF" BorderThickness="0,0,0,1" Padding="32,16">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Style="{StaticResource ActionBtn}" Margin="0,0,8,0"
                                                Click="DetailOpenFolder_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Folder24" FontSize="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Open folder" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ActionBtn}" Margin="0,0,8,0"
                                                Click="DetailArmouryCrate_Click"
                                                Visibility="{Binding IsLanCard, Converter={StaticResource InvBoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Flash24" FontSize="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Armoury Crate" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ActionBtn}" Margin="0,0,8,0"
                                                Click="DetailAddToSteam_Click"
                                                Visibility="{Binding IsLanCard, Converter={StaticResource InvBoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="ArrowExportLtr24" FontSize="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Add to Steam" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ActionBtn}"
                                                Click="DetailRefetchArtwork_Click"
                                                Visibility="{Binding IsLanCard, Converter={StaticResource InvBoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Image24" FontSize="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Refetch artwork" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <Button Style="{StaticResource DangerBtn}" HorizontalAlignment="Right"
                                            Visibility="{Binding IsLanCard, Converter={StaticResource InvBoolToVis}}"
                                            Click="DetailRemove_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Delete24" FontSize="13" Margin="0,0,6,0"/>
                                            <TextBlock Text="Remove" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Cards -->
                            <StackPanel Margin="32,20,32,32">

                                <!-- About -->
                                <Border Style="{StaticResource DetailCard}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="About" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="White" Margin="0,0,0,12"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="13" LineHeight="21"
                                                   Foreground="#D9FFFFFF" TextWrapping="Wrap"
                                                   Visibility="{Binding Description, Converter={StaticResource InvEmptyStrToVis}}"/>
                                        <TextBlock Text="No description. Import metadata via Settings to add game info."
                                                   FontSize="13" Foreground="#66FFFFFF"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding Description, Converter={StaticResource EmptyStrToVis}}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Game settings -->
                                <Border Style="{StaticResource DetailCard}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Game settings" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="White" Margin="0,0,0,12"/>

                                        <!-- Run as Administrator -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                                    Background="#0AFFFFFF" BorderBrush="#0DFFFFFF" BorderThickness="1">
                                                <ui:SymbolIcon Symbol="Shield24" FontSize="16"
                                                               Foreground="#D8FFFFFF"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="Run as administrator"
                                                           FontSize="13" FontWeight="Medium" Foreground="White"/>
                                                <TextBlock Text="Always elevate this game on launch."
                                                           FontSize="12" Foreground="#99FFFFFF"/>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="2"
                                                             x:Name="RunAsAdminToggle"
                                                             IsChecked="{Binding RunAsAdmin, Mode=TwoWay}"
                                                             Checked="RunAsAdmin_Checked"
                                                             Unchecked="RunAsAdmin_Unchecked"
                                                             VerticalAlignment="Center"/>
                                        </Grid>

                                        <Rectangle Height="1" Fill="#0DFFFFFF" Margin="0,10,0,10"/>

                                        <!-- Share on LAN -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                                    Background="#0AFFFFFF" BorderBrush="#0DFFFFFF" BorderThickness="1">
                                                <ui:SymbolIcon Symbol="Wifi224" FontSize="16"
                                                               Foreground="#D8FFFFFF"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="Share on LAN"
                                                           FontSize="13" FontWeight="Medium" Foreground="White"/>
                                                <TextBlock Text="Make this install available to Spool peers."
                                                           FontSize="12" Foreground="#99FFFFFF"/>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="2"
                                                             x:Name="LanShareToggle"
                                                             IsChecked="{Binding LanShared, Mode=TwoWay}"
                                                             Checked="LanShare_Checked"
                                                             Unchecked="LanShare_Unchecked"
                                                             VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- Shared folder (shown when LanShared) -->
                                        <Grid Margin="46,10,0,0"
                                              Visibility="{Binding LanShared, Converter={StaticResource BoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Shared folder" FontSize="12" Foreground="#A6FFFFFF"/>
                                                <TextBlock Text="Defaults to install dir" FontSize="10.5" Foreground="#66FFFFFF" Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <ui:TextBox Grid.Column="1"
                                                        x:Name="LanFolderBox"
                                                        Text="{Binding GameFolderPath, Mode=OneWay}"
                                                        IsReadOnly="True"
                                                        FontFamily="Cascadia Code, Consolas, Courier New"
                                                        FontSize="11"
                                                        Margin="12,0,6,0"/>
                                            <Button Grid.Column="2" Style="{StaticResource ActionBtn}"
                                                    Click="LanFolderBrowse_Click">Browse</Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Save management -->
                                <Border Style="{StaticResource DetailCard}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <!-- Header row -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Save management" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="White" VerticalAlignment="Center"/>
                                                <!-- Backup badge -->
                                                <Border CornerRadius="9" Padding="8,1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1AFFFFFF"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SaveBackupCount, Converter={StaticResource PosIntToVis}}" Value="Visible">
                                                                    <Setter Property="Background" Value="#1F7EE2A4"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="#66FFFFFF"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding SaveBackupCount, Converter={StaticResource PosIntToVis}}" Value="Visible">
                                                                            <Setter Property="Fill" Value="#7EE2A4"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock FontSize="11" FontWeight="Medium" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#8CFFFFFF"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding SaveBackupCount, Converter={StaticResource PosIntToVis}}" Value="Visible">
                                                                            <Setter Property="Foreground" Value="#7EE2A4"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <Run Text="{Binding SaveBackupCount, Mode=OneWay}"/>
                                                            <Run Text=" backups"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                                <Button Style="{StaticResource ActionBtn}" Height="26" Padding="10,0"
                                                        FontSize="12" Margin="0,0,6,0" Click="SaveRestore_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="ArrowCounterclockwise24" FontSize="12" Margin="0,0,5,0"/>
                                                        <TextBlock Text="Restore" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource ActionBtn}" Height="26" Padding="10,0"
                                                        FontSize="12" Click="SaveBackupNow_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="Save24" FontSize="12" Margin="0,0,5,0"/>
                                                        <TextBlock Text="Back up now" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Save stats 3-col -->
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="LAST BACKUP" FontSize="10" FontWeight="Medium"
                                                           Foreground="#80FFFFFF" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding SaveLastBackedUpAt, Converter={StaticResource RelDate}}"
                                                           FontSize="15" FontWeight="Medium" Foreground="White"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="SAVES FOUND" FontSize="10" FontWeight="Medium"
                                                           Foreground="#80FFFFFF" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding SaveBackupCount}"
                                                           FontSize="15" FontWeight="Medium" Foreground="White"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="TOTAL SIZE" FontSize="10" FontWeight="Medium"
                                                           Foreground="#80FFFFFF" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding SaveBackupSizeMb, Converter={StaticResource SizeMbConv}}"
                                                           FontSize="15" FontWeight="Medium" Foreground="White"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Ludusavi banner -->
                                        <Border CornerRadius="4" Padding="12,10" Margin="0,14,0,0"
                                                Background="#0F7EE2A4" BorderBrush="#267EE2A4" BorderThickness="1"
                                                Visibility="{Binding SaveBackupCount, Converter={StaticResource PosIntToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="14"
                                                               Foreground="#7EE2A4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Saves restore automatically before launch and back up on exit via Ludusavi."
                                                           FontSize="12" Foreground="#C8FFFFFF" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Details -->
                                <Border Style="{StaticResource DetailCard}">
                                    <StackPanel>
                                        <TextBlock Text="Details" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="White" Margin="0,0,0,8"/>
                                        <!-- Row: Developer -->
                                        <Grid MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Developer"
                                                       FontSize="12" Foreground="#8CFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Developer}"
                                                       FontSize="12.5" Foreground="#EBFFFFFF"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#0AFFFFFF"/>
                                        <!-- Publisher -->
                                        <Grid MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Publisher"
                                                       FontSize="12" Foreground="#8CFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Publisher}"
                                                       FontSize="12.5" Foreground="#EBFFFFFF"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#0AFFFFFF"/>
                                        <!-- Release date -->
                                        <Grid MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Release date"
                                                       FontSize="12" Foreground="#8CFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ReleaseDate, Converter={StaticResource AbsDate}}"
                                                       FontSize="12.5" Foreground="#EBFFFFFF" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#0AFFFFFF"/>
                                        <!-- Genres -->
                                        <Grid MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Genres"
                                                       FontSize="12" Foreground="#8CFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Genres, Converter={StaticResource GenreListConv}}"
                                                       FontSize="12.5" Foreground="#EBFFFFFF" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#0AFFFFFF"/>
                                        <!-- Added to library -->
                                        <Grid MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Added to library"
                                                       FontSize="12" Foreground="#8CFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding AddedAt, Converter={StaticResource AbsDate}}"
                                                       FontSize="12.5" Foreground="#EBFFFFFF" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#0AFFFFFF"/>
                                        <!-- Executable -->
                                        <Grid MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Executable"
                                                       FontSize="12" Foreground="#8CFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ExePath}"
                                                       FontSize="12" Foreground="#EBFFFFFF" VerticalAlignment="Center"
                                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#0AFFFFFF"/>
                                        <!-- Install path -->
                                        <Grid MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Install path"
                                                       FontSize="12" Foreground="#8CFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding GameFolderPath}"
                                                       FontSize="12" Foreground="#EBFFFFFF" VerticalAlignment="Center"
                                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- ─── Upload bar ─── -->
        <Separator x:Name="UploadSeparator" Grid.Row="2" Visibility="Collapsed" Margin="0"/>
        <Border x:Name="UploadBarGrid" Grid.Row="3"
                Background="{DynamicResource CardBackgroundFillBrushDefault}"
                Padding="24,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="UploadTitleText" Text="Uploading…"
                                   FontWeight="SemiBold" FontSize="13" Grid.Column="0"/>
                        <TextBlock x:Name="UploadStatusText"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12" Grid.Column="1"/>
                    </Grid>
                    <ProgressBar x:Name="UploadProgressBar" Height="8" Minimum="0" Maximum="100" Value="0"/>
                </StackPanel>
                <ui:Button x:Name="CancelUploadButton" Grid.Column="1"
                           Content="Cancel" Appearance="Danger"
                           Margin="16,0,0,0" VerticalAlignment="Center"
                           Click="CancelUpload_Click"/>
            </Grid>
        </Border>

        <!-- ─── Download bar ─── -->
        <Separator x:Name="DownloadSeparator" Grid.Row="4" Visibility="Collapsed" Margin="0"/>
        <Border x:Name="DownloadBarGrid" Grid.Row="5"
                Background="{DynamicResource CardBackgroundFillBrushDefault}"
                Padding="24,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <TextBlock x:Name="DownloadTitleText" Text="Preparing…"
                                       FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock x:Name="DownloadCountText" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="8,1,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Bottom">
                            <TextBlock x:Name="DownloadSpeedText" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,8,0"/>
                            <TextBlock x:Name="DownloadBytesText" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <ProgressBar x:Name="DownloadProgressBar" Height="8" Minimum="0" Maximum="100" Value="0"/>
                </StackPanel>
                <ui:Button x:Name="CancelDownloadButton" Grid.Column="1"
                           Content="Cancel" Appearance="Danger"
                           Margin="16,0,0,0" VerticalAlignment="Center"
                           Visibility="Collapsed"
                           Click="CancelDownload_Click"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
