<ui:FluentWindow x:Class="LudusaviWrap.RunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Ludusavi Wrap"
        Width="0"
        Height="0"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Ludusavi Wrap"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     Grid.Row="0"/>

        <Grid VerticalAlignment="Center" Margin="32,20" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="StatusLabel"
                       Text="Initializing..."
                       FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,16"
                       Grid.Row="0"/>

            <ProgressBar x:Name="LoadProgress"
                            Height="4"
                            IsIndeterminate="True"
                            Grid.Row="1"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
