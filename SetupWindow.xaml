<ui:FluentWindow x:Class="LudusaviWrap.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:LudusaviWrap"
        Title="Settings — Spool"
        Closing="Window_Closing"
        Width="1040"
        Height="720"
        MinHeight="560"
        MinWidth="760"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Nav item style -->
        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill border style -->
        <Style x:Key="StatusPillOk" TargetType="Border">
            <Setter Property="Background" Value="#2350C878"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatusPillWarn" TargetType="Border">
            <Setter Property="Background" Value="#23FFB45A"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Card expander body style -->
        <Style x:Key="ExpanderBody" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="16,14,16,16"/>
        </Style>

        <!-- Sub-label style -->
        <Style x:Key="SubLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Helper text style -->
        <Style x:Key="HelperText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- Section header title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <!-- Section subtitle -->
        <Style x:Key="SectionSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Margin" Value="48,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- TitleBar -->
            <RowDefinition Height="*"/>     <!-- Body -->
            <RowDefinition Height="Auto"/>  <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Title="Settings — Spool"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     Height="40"
                     Grid.Row="0"/>

        <!-- Body: sidebar + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar ── -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Search box -->
                    <Border DockPanel.Dock="Top" Padding="12,16,12,8">
                        <ui:TextBox x:Name="SearchBox"
                                    PlaceholderText="Find a setting"
                                    TextChanged="SearchBox_TextChanged"/>
                    </Border>

                    <!-- Nav list -->
                    <ListBox x:Name="NavList"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="12,0,12,12"
                             SelectionChanged="NavList_SelectionChanged"
                             ItemContainerStyle="{StaticResource NavItemStyle}">
                        <ListBox.Items>
                            <!-- General -->
                            <ListBoxItem x:Name="NavGeneral" Tag="general">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Active indicator -->
                                    <Border x:Name="NavGeneralPill"
                                            Grid.Column="0"
                                            Width="3" Height="18"
                                            CornerRadius="2"
                                            Background="#4CC2FF"
                                            HorizontalAlignment="Left"
                                            Visibility="Hidden"/>
                                    <ui:SymbolIcon Grid.Column="1"
                                                   Symbol="Settings20"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="General"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </ListBoxItem>
                            <!-- Artwork -->
                            <ListBoxItem x:Name="NavArtwork" Tag="artwork">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="NavArtworkPill"
                                            Grid.Column="0"
                                            Width="3" Height="18"
                                            CornerRadius="2"
                                            Background="#4CC2FF"
                                            HorizontalAlignment="Left"
                                            Visibility="Hidden"/>
                                    <ui:SymbolIcon Grid.Column="1"
                                                   Symbol="Image20"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="Artwork"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </ListBoxItem>
                            <!-- Sources -->
                            <ListBoxItem x:Name="NavSources" Tag="sources">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="NavSourcesPill"
                                            Grid.Column="0"
                                            Width="3" Height="18"
                                            CornerRadius="2"
                                            Background="#4CC2FF"
                                            HorizontalAlignment="Left"
                                            Visibility="Hidden"/>
                                    <ui:SymbolIcon Grid.Column="1"
                                                   Symbol="Link20"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="Sources"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </ListBoxItem>
                            <!-- LAN sharing -->
                            <ListBoxItem x:Name="NavLan" Tag="lan">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="NavLanPill"
                                            Grid.Column="0"
                                            Width="3" Height="18"
                                            CornerRadius="2"
                                            Background="#4CC2FF"
                                            HorizontalAlignment="Left"
                                            Visibility="Hidden"/>
                                    <ui:SymbolIcon Grid.Column="1"
                                                   Symbol="Router20"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="LAN sharing"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </ListBoxItem>
                            <!-- Cloud sync -->
                            <ListBoxItem x:Name="NavSync" Tag="sync">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="NavSyncPill"
                                            Grid.Column="0"
                                            Width="3" Height="18"
                                            CornerRadius="2"
                                            Background="#4CC2FF"
                                            HorizontalAlignment="Left"
                                            Visibility="Hidden"/>
                                    <ui:SymbolIcon Grid.Column="1"
                                                   Symbol="ArrowSync20"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="Cloud sync"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </ListBoxItem>
                            <!-- Downloads -->
                            <ListBoxItem x:Name="NavDownloads" Tag="downloads">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="NavDownloadsPill"
                                            Grid.Column="0"
                                            Width="3" Height="18"
                                            CornerRadius="2"
                                            Background="#4CC2FF"
                                            HorizontalAlignment="Left"
                                            Visibility="Hidden"/>
                                    <ui:SymbolIcon Grid.Column="1"
                                                   Symbol="ArrowDownload20"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="Downloads"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </ListBoxItem>
                        </ListBox.Items>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ── Content area ── -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid MaxWidth="720" Margin="32,26,32,32" HorizontalAlignment="Stretch">

                    <!-- ════ GENERAL ════ -->
                    <StackPanel x:Name="SectionGeneral" Visibility="Collapsed">
                        <!-- Header -->
                        <StackPanel Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <ui:SymbolIcon Symbol="Settings20" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Style="{StaticResource SectionTitle}" Text="General" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource SectionSubtitle}" Text="Core paths and app behaviour."/>
                        </StackPanel>

                        <StackPanel>
                            <!-- Ludusavi executable card -->
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                        <ui:SymbolIcon Symbol="Folder20" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Ludusavi executable" FontWeight="Medium" FontSize="13"/>
                                            <Border x:Name="LudusaviPill" Style="{StaticResource StatusPillOk}" Margin="8,0,0,0" Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Fill="#7EE2A4" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock x:Name="LudusaviPillText" Text="Detected" FontSize="11" FontWeight="Medium" Foreground="#7EE2A4"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Path to ludusavi.exe — used for save backup and restore."
                                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:TextBox x:Name="LudusaviPathTextBox"
                                                    PlaceholderText="C:\Path\to\ludusavi.exe"
                                                    Width="260"
                                                    FontFamily="Cascadia Code, Consolas, monospace"
                                                    FontSize="12"
                                                    Margin="0,0,6,0"
                                                    TextChanged="LudusaviPath_TextChanged"/>
                                        <ui:Button Content="Browse"
                                                   Appearance="Secondary"
                                                   Click="BrowseLudusavi_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Theme card -->
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                        <ui:SymbolIcon Symbol="DarkTheme20" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Theme" FontWeight="Medium" FontSize="13"/>
                                        <TextBlock Text="Match Windows, or override with light or dark."
                                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="ThemeSystemRadio"
                                                     Content="System"
                                                     Margin="0,0,12,0"
                                                     Checked="ThemeRadio_Changed"/>
                                        <RadioButton x:Name="ThemeLightRadio"
                                                     Content="Light"
                                                     Margin="0,0,12,0"
                                                     Checked="ThemeRadio_Changed"/>
                                        <RadioButton x:Name="ThemeDarkRadio"
                                                     Content="Dark"
                                                     Checked="ThemeRadio_Changed"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Touch Optimization card -->
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                        <ui:SymbolIcon Symbol="HandDraw20" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Touch Optimization" FontWeight="Medium" FontSize="13"/>
                                        <TextBlock Text="Optimize button sizes, padding, and inputs for touchscreens."
                                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="TouchOptimizedSwitch"
                                                     Grid.Column="3"
                                                     VerticalAlignment="Center"
                                                     Checked="TouchOptimizedSwitch_Changed"
                                                     Unchecked="TouchOptimizedSwitch_Changed"/>
                                </Grid>
                            </Border>

                            <!-- About card -->
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                        <ui:SymbolIcon Symbol="Info20" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="About" FontWeight="Medium" FontSize="13"/>
                                        <TextBlock x:Name="AboutVersionText"
                                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ui:Button x:Name="ReleaseNotesButton"
                                               Grid.Column="3"
                                               Content="Release notes"
                                               Appearance="Secondary"
                                               VerticalAlignment="Center"
                                               Click="ReleaseNotes_Click"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- ════ ARTWORK ════ -->
                    <StackPanel x:Name="SectionArtwork" Visibility="Collapsed">
                        <StackPanel Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <ui:SymbolIcon Symbol="Image20" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Artwork" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource SectionSubtitle}" Text="Automatically fetch cover art for your library and launcher shortcuts."/>
                        </StackPanel>

                        <!-- SteamGridDB expandable card -->
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                            <StackPanel>
                                <!-- Row -->
                                <Grid Margin="16,14" Cursor="Hand" MouseLeftButtonUp="SgdbCard_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                        <ui:SymbolIcon Symbol="Image20" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="SteamGridDB" FontWeight="Medium" FontSize="13"/>
                                            <Border x:Name="SgdbPill" Style="{StaticResource StatusPillOk}" Margin="8,0,0,0" Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Fill="#7EE2A4" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock Text="Authenticated" FontSize="11" FontWeight="Medium" Foreground="#7EE2A4"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Download cover images automatically when generating a wrapper."
                                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:ToggleSwitch x:Name="SgdbSwitch"
                                                         Margin="0,0,10,0"
                                                         Checked="SgdbSwitch_Changed"
                                                         Unchecked="SgdbSwitch_Changed"
                                                         PreviewMouseLeftButtonUp="SgdbSwitch_PreviewClick"/>
                                        <ui:SymbolIcon x:Name="SgdbChevron" Symbol="ChevronDown20" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Expanded body -->
                                <Border x:Name="SgdbBody" Style="{StaticResource ExpanderBody}" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="API Key" Style="{StaticResource SubLabel}"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ui:TextBox Grid.Column="0"
                                                            x:Name="ApiKeyTextBox"
                                                            PlaceholderText="Paste API key…"
                                                            FontFamily="Cascadia Code, Consolas, monospace"
                                                            FontSize="12"
                                                            Margin="0,0,6,0"/>
                                                <ui:Button Grid.Column="1"
                                                           Content="Get key"
                                                           Appearance="Secondary"
                                                           Click="GetKey_Click"/>
                                            </Grid>
                                            <TextBlock Style="{StaticResource HelperText}"
                                                       Text="Required to download cover, hero, and logo artwork."/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ════ SOURCES ════ -->
                    <StackPanel x:Name="SectionSources" Visibility="Collapsed">
                        <StackPanel Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <ui:SymbolIcon Symbol="Link20" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Download sources" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource SectionSubtitle}" Text="Hydra-compatible JSON source URLs used by the Browse Games window."/>
                        </StackPanel>

                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <!-- Add row -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox Grid.Column="0"
                                                x:Name="NewSourceUrlTextBox"
                                                PlaceholderText="https://example.com/source.json"
                                                FontFamily="Cascadia Code, Consolas, monospace"
                                                FontSize="12"
                                                Margin="0,0,6,0"/>
                                    <ui:Button Grid.Column="1"
                                               Content="Add"
                                               Appearance="Primary"
                                               Click="AddSource_Click"/>
                                </Grid>

                                <!-- List -->
                                <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}" MaxHeight="220">
                                    <ListBox x:Name="SourcesListBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Grid.Column="0" Width="6" Height="6" Fill="#7EE2A4"
                                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding}"
                                                               FontFamily="Cascadia Code, Consolas, monospace"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"
                                                               ToolTip="{Binding}"/>
                                                    <Button Grid.Column="2"
                                                            Content="✕"
                                                            Tag="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                            Cursor="Hand"
                                                            FontSize="11"
                                                            Padding="4,2"
                                                            Click="RemoveSource_Click"
                                                            VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="12,7"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="BorderBrush" Value="#4cc2ff"/>
                                                        <Setter Property="Background" Value="#1F4CC2FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#0AFFFFFF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>

                                <!-- Footer count -->
                                <TextBlock x:Name="SourcesCountLabel"
                                           FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ════ LAN SHARING ════ -->
                    <StackPanel x:Name="SectionLan" Visibility="Collapsed">
                        <StackPanel Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <ui:SymbolIcon Symbol="Router20" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Style="{StaticResource SectionTitle}" Text="LAN sharing" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource SectionSubtitle}" Text="Share installed games with other devices on your local network."/>
                        </StackPanel>

                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                            <StackPanel>
                                <Grid Margin="16,14" Cursor="Hand" MouseLeftButtonUp="LanCard_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                        <ui:SymbolIcon Symbol="Router20" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="LAN game transfer" FontWeight="Medium" FontSize="13"/>
                                            <Border x:Name="LanPill" Style="{StaticResource StatusPillOk}" Margin="8,0,0,0" Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Fill="#7EE2A4" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock x:Name="LanPillText" FontSize="11" FontWeight="Medium" Foreground="#7EE2A4"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Other devices on the same network can browse and pull installs from this machine."
                                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:ToggleSwitch x:Name="LanSwitch"
                                                         Margin="0,0,10,0"
                                                         Checked="LanSwitch_Changed"
                                                         Unchecked="LanSwitch_Changed"
                                                         PreviewMouseLeftButtonUp="LanSwitch_PreviewClick"/>
                                        <ui:SymbolIcon x:Name="LanChevron" Symbol="ChevronDown20" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <Border x:Name="LanBody" Style="{StaticResource ExpanderBody}" Visibility="Collapsed">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Port" Style="{StaticResource SubLabel}"/>
                                            <StackPanel Grid.Column="1">
                                                <ui:TextBox x:Name="LanPortTextBox"
                                                            PlaceholderText="47632"
                                                            FontFamily="Cascadia Code, Consolas, monospace"
                                                            FontSize="12"
                                                            Width="140"
                                                            HorizontalAlignment="Left"/>
                                                <TextBlock Style="{StaticResource HelperText}"
                                                           Text="TCP port that peers connect to. Default 47632."/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Default install dir" Style="{StaticResource SubLabel}"/>
                                            <StackPanel Grid.Column="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox Grid.Column="0"
                                                                x:Name="LanInstallDirTextBox"
                                                                IsReadOnly="True"
                                                                PlaceholderText="Where downloads go by default…"
                                                                FontFamily="Cascadia Code, Consolas, monospace"
                                                                FontSize="12"
                                                                Margin="0,0,6,0"/>
                                                    <ui:Button Grid.Column="1"
                                                               Content="Browse"
                                                               Appearance="Secondary"
                                                               Click="BrowseLanInstallDir_Click"/>
                                                </Grid>
                                                <TextBlock Style="{StaticResource HelperText}"
                                                           Text="Where downloads from peers land by default."/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ════ CLOUD SYNC ════ -->
                    <StackPanel x:Name="SectionSync" Visibility="Collapsed">
                        <StackPanel Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <ui:SymbolIcon Symbol="ArrowSync20" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Cloud sync" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource SectionSubtitle}" Text="Keep saves, playtime, and play state in sync across all your devices."/>
                        </StackPanel>

                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                            <StackPanel>
                                <Grid Margin="16,14" Cursor="Hand" MouseLeftButtonUp="SyncCard_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                        <ui:SymbolIcon Symbol="ArrowSync20" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Sync server" FontWeight="Medium" FontSize="13"/>
                                            <Border x:Name="SyncPill" Style="{StaticResource StatusPillOk}" Margin="8,0,0,0" Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Fill="#7EE2A4" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock x:Name="SyncPillText" FontSize="11" FontWeight="Medium" Foreground="#7EE2A4"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Syncs saves, playtime, last played, and session locks across your devices."
                                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:ToggleSwitch x:Name="SyncSwitch"
                                                         Margin="0,0,10,0"
                                                         Checked="SyncSwitch_Changed"
                                                         Unchecked="SyncSwitch_Changed"
                                                         PreviewMouseLeftButtonUp="SyncSwitch_PreviewClick"/>
                                        <ui:SymbolIcon x:Name="SyncChevron" Symbol="ChevronDown20" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <Border x:Name="SyncBody" Style="{StaticResource ExpanderBody}" Visibility="Collapsed">
                                    <StackPanel>
                                        <!-- Server URL -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Server URL" Style="{StaticResource SubLabel}"/>
                                            <StackPanel Grid.Column="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox Grid.Column="0"
                                                                x:Name="SyncUrlTextBox"
                                                                PlaceholderText="http://raspberrypi.local:47633"
                                                                FontFamily="Cascadia Code, Consolas, monospace"
                                                                FontSize="12"
                                                                Margin="0,0,6,0"/>
                                                    <ui:Button Grid.Column="1"
                                                               x:Name="ScanLanButton"
                                                               Content="Scan LAN"
                                                               Appearance="Secondary"
                                                               Click="ScanLan_Click"/>
                                                </Grid>
                                                <TextBlock Style="{StaticResource HelperText}"
                                                           Text="HTTP endpoint of your sync server (LAN or remote)."/>
                                                <TextBlock x:Name="ServerVersionLabel"
                                                           FontSize="11"
                                                           Margin="0,4,0,0"
                                                           Visibility="Collapsed"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- API key -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="API key" Style="{StaticResource SubLabel}"/>
                                            <StackPanel Grid.Column="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:PasswordBox Grid.Column="0"
                                                                    x:Name="SyncApiKeyBox"
                                                                    FontFamily="Cascadia Code, Consolas, monospace"
                                                                    FontSize="12"
                                                                    Margin="0,0,6,0"/>
                                                    <ui:Button Grid.Column="1"
                                                               Content="Register…"
                                                               Appearance="Secondary"
                                                               Click="RegisterPanel_Toggle"/>
                                                </Grid>
                                                <TextBlock x:Name="SyncApiKeyHelper"
                                                           Style="{StaticResource HelperText}"
                                                           Text="Register a device to obtain an API key."/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Device name -->
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Device name" Style="{StaticResource SubLabel}"/>
                                            <ui:TextBox Grid.Column="1"
                                                        x:Name="DeviceNameTextBox"
                                                        PlaceholderText="PC name shown to other devices"/>
                                        </Grid>

                                        <!-- Inline register panel -->
                                        <Border x:Name="RegisterPanel"
                                                Visibility="Collapsed"
                                                Background="#0D4CC2FF"
                                                BorderBrush="#334CC2FF"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="12,10"
                                                Margin="0,12,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Register a new device with this server"
                                                           FontSize="12" FontWeight="Medium"
                                                           Foreground="#4CC2FF"
                                                           Margin="0,0,0,10"/>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Admin secret" Style="{StaticResource SubLabel}"/>
                                                    <ui:PasswordBox Grid.Column="1"
                                                                    x:Name="RegisterAdminSecretBox"
                                                                    FontFamily="Cascadia Code, Consolas, monospace"
                                                                    FontSize="12"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Username" Style="{StaticResource SubLabel}"/>
                                                    <ui:TextBox Grid.Column="1"
                                                                x:Name="RegisterUsernameBox"
                                                                PlaceholderText="alex"/>
                                                </Grid>
                                                <TextBlock x:Name="RegisterErrorLabel"
                                                           FontSize="11"
                                                           Foreground="#FF8A8A"
                                                           Margin="0,0,0,6"
                                                           Visibility="Collapsed"
                                                           TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right">
                                                    <ui:Button Content="Cancel"
                                                               Appearance="Secondary"
                                                               Margin="0,0,6,0"
                                                               Click="RegisterCancel_Click"/>
                                                    <ui:Button x:Name="RegisterButton"
                                                               Content="Register"
                                                               Appearance="Primary"
                                                               Click="Register_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ════ DOWNLOADS ════ -->
                    <StackPanel x:Name="SectionDownloads" Visibility="Collapsed">
                        <StackPanel Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <ui:SymbolIcon Symbol="ArrowDownload20" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Downloads" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource SectionSubtitle}" Text="External download providers for fetching game files."/>
                        </StackPanel>

                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                            <StackPanel>
                                <Grid Margin="16,14" Cursor="Hand" MouseLeftButtonUp="TorBoxCard_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                        <ui:SymbolIcon Symbol="ArrowDownload20" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="TorBox" FontWeight="Medium" FontSize="13"/>
                                            <Border x:Name="TorBoxPill" Style="{StaticResource StatusPillOk}" Margin="8,0,0,0" Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Fill="#7EE2A4" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock Text="Linked" FontSize="11" FontWeight="Medium" Foreground="#7EE2A4"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Download game files via the TorBox debrid service."
                                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:ToggleSwitch x:Name="TorBoxSwitch"
                                                         Margin="0,0,10,0"
                                                         Checked="TorBoxSwitch_Changed"
                                                         Unchecked="TorBoxSwitch_Changed"
                                                         PreviewMouseLeftButtonUp="TorBoxSwitch_PreviewClick"/>
                                        <ui:SymbolIcon x:Name="TorBoxChevron" Symbol="ChevronDown20" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <Border x:Name="TorBoxBody" Style="{StaticResource ExpanderBody}" Visibility="Collapsed">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="API key" Style="{StaticResource SubLabel}"/>
                                            <StackPanel Grid.Column="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:PasswordBox Grid.Column="0"
                                                                 x:Name="TorBoxApiKeyBox"
                                                                 FontFamily="Cascadia Code, Consolas, monospace"
                                                                 FontSize="12"
                                                                 Margin="0,0,6,0"/>
                                                    <ui:Button Grid.Column="1"
                                                               Content="Get key"
                                                               Appearance="Secondary"
                                                               Click="TorBoxGetKey_Click"/>
                                                </Grid>
                                                <TextBlock Style="{StaticResource HelperText}"
                                                           Text="Required to authorise download requests."/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Download to" Style="{StaticResource SubLabel}"/>
                                            <StackPanel Grid.Column="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox Grid.Column="0"
                                                                x:Name="TorBoxDownloadDirTextBox"
                                                                IsReadOnly="True"
                                                                PlaceholderText="Default: ~/Downloads"
                                                                FontFamily="Cascadia Code, Consolas, monospace"
                                                                FontSize="12"
                                                                Margin="0,0,6,0"/>
                                                    <ui:Button Grid.Column="1"
                                                               Content="Browse"
                                                               Appearance="Secondary"
                                                               Click="BrowseTorBoxDir_Click"/>
                                                </Grid>
                                                <TextBlock Style="{StaticResource HelperText}"
                                                           Text="Where TorBox-fetched files land."/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ── Action bar ── -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                Height="60">
            <Grid Margin="24,0">
                <!-- Unsaved indicator -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Ellipse x:Name="DirtyDot" Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="DirtyLabel" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <ui:Button Content="Cancel"
                               Appearance="Secondary"
                               Width="100"
                               Margin="0,0,8,0"
                               Click="Cancel_Click"/>
                    <ui:Button Content="Save &amp; Continue"
                               Appearance="Primary"
                               Width="160"
                               Click="Save_Click"/>
                </StackPanel>

                <!-- Error label (centered) -->
                <TextBlock x:Name="ErrorLabel"
                           Foreground="#FF8A8A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
