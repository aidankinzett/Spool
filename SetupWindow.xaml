<ui:FluentWindow x:Class="LudusaviWrap.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:LudusaviWrap"
        Title="Settings"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Settings"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Ludusavi Path card -->
                <RowDefinition Height="Auto"/> <!-- SteamGridDB card -->
                <RowDefinition Height="Auto"/> <!-- Appearance card -->
                <RowDefinition Height="Auto"/> <!-- Sync Server card -->
                <RowDefinition Height="Auto"/> <!-- Error label -->
                <RowDefinition Height="Auto"/> <!-- Action buttons -->
            </Grid.RowDefinitions>

            <!-- Ludusavi Path card -->
            <ui:Card Margin="0,0,0,12" Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="Ludusavi Path"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="LudusaviPathTextBox"
                                    PlaceholderText="C:\Path\to\ludusavi.exe"
                                    Grid.Column="0"
                                    Margin="0,0,8,0"/>
                        <ui:Button Content="Browse"
                                   Appearance="Secondary"
                                   Click="BrowseLudusavi_Click"
                                   Grid.Column="1"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- SteamGridDB card -->
            <ui:Card Margin="0,0,0,12" Grid.Row="1">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SteamGridDB Artwork"
                                   FontWeight="SemiBold"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"/>
                        <ui:ToggleSwitch x:Name="SgdbSwitch"
                                         Checked="SgdbSwitch_Changed"
                                         Unchecked="SgdbSwitch_Changed"
                                         Grid.Column="1"
                                         VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Download cover images automatically when generating a wrapper."
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="11"
                               Margin="0,0,0,12"/>

                    <Grid x:Name="ApiKeyGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="API Key:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Grid.Column="0"/>
                        <ui:TextBox x:Name="ApiKeyTextBox"
                                    PlaceholderText="Paste API Key here"
                                    Margin="0,0,8,0"
                                    Grid.Column="1"/>
                        <ui:Button Content="Get Key"
                                   Appearance="Secondary"
                                   Click="GetKey_Click"
                                   Grid.Column="2"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Appearance card -->
            <ui:Card Margin="0,0,0,12" Grid.Row="2">
                <StackPanel>
                    <TextBlock Text="Appearance"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Theme:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   Grid.Column="0"/>
                        <ComboBox x:Name="ThemeComboBox"
                                  SelectionChanged="ThemeComboBox_SelectionChanged"
                                  Grid.Column="1">
                            <ComboBoxItem x:Name="ThemeSystem" Content="System default" Tag="system"/>
                            <ComboBoxItem x:Name="ThemeLight"  Content="Light"          Tag="light"/>
                            <ComboBoxItem x:Name="ThemeDark"   Content="Dark"           Tag="dark"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Sync Server card -->
            <ui:Card Margin="0,0,0,12" Grid.Row="3">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Sync Server"
                                   FontWeight="SemiBold"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"/>
                        <ui:ToggleSwitch x:Name="SyncSwitch"
                                         Checked="SyncSwitch_Changed"
                                         Unchecked="SyncSwitch_Changed"
                                         Grid.Column="1"
                                         VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Prevents launching a game that&#x2019;s already running on another device."
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="11"
                               Margin="0,0,0,12"/>

                    <Grid x:Name="SyncFieldsGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Server URL:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,8"
                                   Grid.Row="0" Grid.Column="0"/>
                        <ui:TextBox x:Name="SyncUrlTextBox"
                                    PlaceholderText="https://your-server.fly.dev"
                                    Margin="0,0,0,8"
                                    Grid.Row="0" Grid.Column="1"/>

                        <TextBlock Text="API Key:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,8"
                                   Grid.Row="1" Grid.Column="0"/>
                        <PasswordBox x:Name="SyncApiKeyBox"
                                     Margin="0,0,0,8"
                                     Grid.Row="1" Grid.Column="1"/>

                        <TextBlock Text="Device Name:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Grid.Row="2" Grid.Column="0"/>
                        <ui:TextBox x:Name="DeviceNameTextBox"
                                    PlaceholderText="PC name shown to other devices"
                                    Grid.Row="2" Grid.Column="1"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Error label -->
            <TextBlock x:Name="ErrorLabel"
                       Foreground="#FF5F5F"
                       HorizontalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"
                       Visibility="Collapsed"
                       Grid.Row="4"/>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Grid.Row="5">
                <ui:Button Content="Save &amp; Continue"
                           Appearance="Primary"
                           Width="160"
                           Click="Save_Click"
                           Margin="0,0,12,0"/>
                <ui:Button Content="Cancel"
                           Appearance="Secondary"
                           Width="100"
                           Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
