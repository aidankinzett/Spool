<ui:FluentWindow x:Class="LudusaviWrap.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:LudusaviWrap"
        Title="Settings"
        Width="880"
        Height="650"
        MinHeight="450"
        MinWidth="800"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Settings"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/> <!-- Columns container -->
                <RowDefinition Height="Auto"/> <!-- Error label -->
                <RowDefinition Height="Auto"/> <!-- Action buttons -->
            </Grid.RowDefinitions>

            <!-- Columns container wrapped in ScrollViewer -->
            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,16">
                <Grid Margin="0,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0">
                    <!-- Ludusavi Path card -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Ludusavi Path"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBox x:Name="LudusaviPathTextBox"
                                            PlaceholderText="C:\Path\to\ludusavi.exe"
                                            Grid.Column="0"
                                            Margin="0,0,8,0"/>
                                <ui:Button Content="Browse"
                                           Appearance="Secondary"
                                           Click="BrowseLudusavi_Click"
                                           Grid.Column="1"/>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- SteamGridDB card -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SteamGridDB Artwork"
                                           FontWeight="SemiBold"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <ui:ToggleSwitch x:Name="SgdbSwitch"
                                                 Checked="SgdbSwitch_Changed"
                                                 Unchecked="SgdbSwitch_Changed"
                                                 Grid.Column="1"
                                                 VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Download cover images automatically when generating a wrapper."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,12"/>

                            <Grid x:Name="ApiKeyGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="API Key:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Grid.Column="0"/>
                                <ui:TextBox x:Name="ApiKeyTextBox"
                                            PlaceholderText="Paste API Key here"
                                            Margin="0,0,8,0"
                                            Grid.Column="1"/>
                                <ui:Button Content="Get Key"
                                           Appearance="Secondary"
                                           Click="GetKey_Click"
                                           Grid.Column="2"/>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Appearance card -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Appearance"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Theme:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"
                                           Grid.Column="0"/>
                                <ComboBox x:Name="ThemeComboBox"
                                          SelectionChanged="ThemeComboBox_SelectionChanged"
                                          Grid.Column="1">
                                    <ComboBoxItem x:Name="ThemeSystem" Content="System default" Tag="system"/>
                                    <ComboBoxItem x:Name="ThemeLight"  Content="Light"          Tag="light"/>
                                    <ComboBoxItem x:Name="ThemeDark"   Content="Dark"           Tag="dark"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Sync Server card -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sync Server"
                                           FontWeight="SemiBold"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <ui:ToggleSwitch x:Name="SyncSwitch"
                                                 Checked="SyncSwitch_Changed"
                                                 Unchecked="SyncSwitch_Changed"
                                                 Grid.Column="1"
                                                 VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Prevents launching a game that&#x2019;s already running on another device."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,12"/>

                            <Grid x:Name="SyncFieldsGrid">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Server URL:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,8"
                                           Grid.Row="0" Grid.Column="0"/>
                                <ui:TextBox x:Name="SyncUrlTextBox"
                                            PlaceholderText="http://raspberrypi.local:47633"
                                            Margin="0,0,8,8"
                                            Grid.Row="0" Grid.Column="1"/>
                                <ui:Button x:Name="ScanLanButton"
                                           Content="Scan LAN"
                                           Appearance="Secondary"
                                           Margin="0,0,0,8"
                                           Click="ScanLan_Click"
                                           Grid.Row="0" Grid.Column="2"/>

                                <!-- Server version status (shown after a health check) -->
                                <TextBlock x:Name="ServerVersionLabel"
                                           Visibility="Collapsed"
                                           FontSize="11"
                                           Margin="0,0,0,8"
                                           Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"/>

                                <TextBlock Text="API Key:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,8"
                                           Grid.Row="2" Grid.Column="0"/>
                                <PasswordBox x:Name="SyncApiKeyBox"
                                             Margin="0,0,8,8"
                                             Grid.Row="2" Grid.Column="1"/>
                                <ui:Button Content="Register..."
                                           Appearance="Secondary"
                                           Margin="0,0,0,8"
                                           Click="RegisterPanel_Toggle"
                                           Grid.Row="2" Grid.Column="2"/>

                                <TextBlock Text="Device Name:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,8"
                                           Grid.Row="3" Grid.Column="0"/>
                                <ui:TextBox x:Name="DeviceNameTextBox"
                                            PlaceholderText="PC name shown to other devices"
                                            Margin="0,0,0,8"
                                            Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"/>

                                <!-- Inline registration panel (hidden until Register... is clicked) -->
                                <Border x:Name="RegisterPanel"
                                        Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                        Visibility="Collapsed"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Padding="12,10"
                                        Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Admin Secret:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,8"
                                                   Grid.Row="0" Grid.Column="0"/>
                                        <PasswordBox x:Name="RegisterAdminSecretBox"
                                                     Margin="0,0,8,8"
                                                     Grid.Row="0" Grid.Column="1"/>
                                        <ui:Button Content="Register"
                                                   Appearance="Primary"
                                                   Margin="0,0,0,8"
                                                   Click="Register_Click"
                                                   Grid.Row="0" Grid.Column="2"/>

                                        <TextBlock Text="Username:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   Grid.Row="1" Grid.Column="0"/>
                                        <ui:TextBox x:Name="RegisterUsernameBox"
                                                    Margin="0,0,8,0"
                                                    Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"/>

                                        <TextBlock x:Name="RegisterErrorLabel"
                                                   Foreground="#FF5F5F"
                                                   FontSize="11"
                                                   Margin="0,6,0,0"
                                                   Visibility="Collapsed"
                                                   Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2">

                    <!-- LAN Share card -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="LAN Game Transfer"
                                           FontWeight="SemiBold"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <ui:ToggleSwitch x:Name="LanSwitch"
                                                 Checked="LanSwitch_Changed"
                                                 Unchecked="LanSwitch_Changed"
                                                 Grid.Column="1"
                                                 VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Share game files with other devices on your local network."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,12"/>

                            <Grid x:Name="LanFieldsGrid">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Port:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,8"
                                           Grid.Row="0" Grid.Column="0"/>
                                <ui:TextBox x:Name="LanPortTextBox"
                                            PlaceholderText="47632"
                                            Margin="0,0,0,8"
                                            Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"/>

                                <TextBlock Text="Default install dir:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Grid.Row="1" Grid.Column="0"/>
                                <ui:TextBox x:Name="LanInstallDirTextBox"
                                            IsReadOnly="True"
                                            PlaceholderText="Where downloads go by default..."
                                            Margin="0,0,8,0"
                                            Grid.Row="1" Grid.Column="1"/>
                                <ui:Button Content="Browse"
                                           Appearance="Secondary"
                                           Click="BrowseLanInstallDir_Click"
                                           Grid.Row="1" Grid.Column="2"/>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- TorBox card -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TorBox Downloader"
                                           FontWeight="SemiBold"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <ui:ToggleSwitch x:Name="TorBoxSwitch"
                                                 Checked="TorBoxSwitch_Changed"
                                                 Unchecked="TorBoxSwitch_Changed"
                                                 Grid.Column="1"
                                                 VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Download game files via TorBox debrid service."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,12"/>

                            <Grid x:Name="TorBoxFieldsGrid">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="API Key:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,8"
                                           Grid.Row="0" Grid.Column="0"/>
                                <PasswordBox x:Name="TorBoxApiKeyBox"
                                             Margin="0,0,8,8"
                                             Grid.Row="0" Grid.Column="1"/>
                                <ui:Button Content="Get Key"
                                           Appearance="Secondary"
                                           Click="TorBoxGetKey_Click"
                                           Margin="0,0,0,8"
                                           Grid.Row="0" Grid.Column="2"/>

                                <TextBlock Text="Download to:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Grid.Row="1" Grid.Column="0"/>
                                <ui:TextBox x:Name="TorBoxDownloadDirTextBox"
                                            IsReadOnly="True"
                                            PlaceholderText="Default: ~/Downloads"
                                            Margin="0,0,8,0"
                                            Grid.Row="1" Grid.Column="1"/>
                                <ui:Button Content="Browse"
                                           Appearance="Secondary"
                                           Click="BrowseTorBoxDir_Click"
                                           Grid.Row="1" Grid.Column="2"/>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Download Sources card -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Download Sources"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Hydra-compatible JSON source URLs for browsing games."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,8"/>

                            <ListBox x:Name="SourcesListBox"
                                     Height="88"
                                     Margin="0,0,0,8"
                                     Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="11"
                                                   ToolTip="{Binding}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBox x:Name="NewSourceUrlTextBox"
                                            PlaceholderText="https://example.com/source.json"
                                            Grid.Column="0"/>
                                <ui:Button Content="Add"
                                           Appearance="Primary"
                                           Click="AddSource_Click"
                                           Grid.Column="2"/>
                                <ui:Button Content="Remove"
                                           Appearance="Secondary"
                                           Click="RemoveSource_Click"
                                           Grid.Column="4"/>
                            </Grid>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </Grid>
            </ScrollViewer>

            <!-- Error label -->
            <TextBlock x:Name="ErrorLabel"
                       Foreground="#FF5F5F"
                       HorizontalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"
                       Visibility="Collapsed"
                       Grid.Row="1"/>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Grid.Row="2">
                <ui:Button Content="Save &amp; Continue"
                           Appearance="Primary"
                           Width="160"
                           Click="Save_Click"
                           Margin="0,0,12,0"/>
                <ui:Button Content="Cancel"
                           Appearance="Secondary"
                           Width="100"
                           Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
