<Window x:Class="LudusaviWrap.SuccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ready for Armoury Crate" 
        Width="500" 
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        Background="{StaticResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="Auto"/> <!-- Game Name Row -->
            <RowDefinition Height="Auto"/> <!-- Launcher Path Row -->
            <RowDefinition Height="Auto"/> <!-- Separator -->
            <RowDefinition Height="Auto"/> <!-- Steps Group -->
            <RowDefinition Height="Auto"/> <!-- Cover Art Status -->
            <RowDefinition Height="Auto"/> <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Ready for Armoury Crate" 
                   FontSize="16" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,16"
                   Grid.Row="0"/>

        <!-- Game Name Input Row -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Game Name" 
                       FontWeight="SemiBold" 
                       FontSize="11" 
                       Foreground="{StaticResource TextMutedBrush}" 
                       Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="GameNameTextBox" 
                         IsReadOnly="True" 
                         Margin="0,0,8,0"
                         Grid.Column="0"/>
                <Button x:Name="CopyNameButton" 
                        Content="Copy" 
                        Width="70"
                        Style="{StaticResource SecondaryButton}" 
                        Click="CopyName_Click"
                        Grid.Column="1"/>
            </Grid>
        </StackPanel>

        <!-- Launcher Path Input Row -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Launcher EXE Path" 
                       FontWeight="SemiBold" 
                       FontSize="11" 
                       Foreground="{StaticResource TextMutedBrush}" 
                       Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="LauncherPathTextBox" 
                         IsReadOnly="True" 
                         Margin="0,0,8,0"
                         Grid.Column="0"/>
                <Button x:Name="CopyPathButton" 
                        Content="Copy" 
                        Width="70"
                        Style="{StaticResource SecondaryButton}" 
                        Click="CopyPath_Click"
                        Grid.Column="1"/>
            </Grid>
        </StackPanel>

        <!-- Separator -->
        <Border BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,1,0,0" 
                Margin="0,8,0,12" 
                Grid.Row="3"/>

        <!-- Steps Group -->
        <StackPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock Text="Next Steps" 
                       FontWeight="Bold" 
                       FontSize="13" 
                       Foreground="{StaticResource TextBrush}" 
                       Margin="0,0,0,6"/>
            <TextBlock Foreground="{StaticResource TextBrush}" 
                       LineHeight="18"
                       TextWrapping="Wrap">
                1.  Open Armoury Crate → Library → Manage Library (Add Game)<LineBreak/>
                2.  Browse and select the generated launcher .exe<LineBreak/>
                3.  (Optional) Add cover art manually if downloaded (path shown below)
            </TextBlock>
        </StackPanel>

        <!-- Cover Art Status -->
        <TextBlock x:Name="ArtworkStatusLabel" 
                   Text="" 
                   FontSize="11" 
                   TextWrapping="Wrap"
                   Foreground="{StaticResource TextMutedBrush}"
                   Margin="0,0,0,16"
                   Grid.Row="5"/>

        <!-- Actions -->
        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Grid.Row="6">
            <Button Content="Open Launchers Folder" 
                    Width="180" 
                    Click="OpenFolder_Click" 
                    Margin="0,0,12,0"/>
            <Button Content="New Wrapper" 
                    Style="{StaticResource SecondaryButton}" 
                    Width="110" 
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
