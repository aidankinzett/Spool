<ui:FluentWindow x:Class="LudusaviWrap.SuccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Ready for Armoury Crate"
        Width="500"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Ready for Armoury Crate"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Game name row -->
                <RowDefinition Height="Auto"/> <!-- Launcher path row -->
                <RowDefinition Height="Auto"/> <!-- Separator -->
                <RowDefinition Height="Auto"/> <!-- Next steps -->
                <RowDefinition Height="Auto"/> <!-- Cover art status -->
                <RowDefinition Height="Auto"/> <!-- Actions -->
            </Grid.RowDefinitions>

            <!-- Game name row -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="GAME NAME"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="GameNameTextBox"
                                IsReadOnly="True"
                                Margin="0,0,8,0"
                                Grid.Column="0"/>
                    <ui:Button x:Name="CopyNameButton"
                               Content="Copy"
                               Appearance="Secondary"
                               Width="70"
                               Click="CopyName_Click"
                               Grid.Column="1"/>
                </Grid>
            </StackPanel>

            <!-- Launcher path row -->
            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="LAUNCHER EXE PATH"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="LauncherPathTextBox"
                                IsReadOnly="True"
                                Margin="0,0,8,0"
                                Grid.Column="0"/>
                    <ui:Button x:Name="CopyPathButton"
                               Content="Copy"
                               Appearance="Secondary"
                               Width="70"
                               Click="CopyPath_Click"
                               Grid.Column="1"/>
                </Grid>
            </StackPanel>

            <!-- Separator -->
            <Separator Grid.Row="2" Margin="0,4,0,12"/>

            <!-- Next steps -->
            <StackPanel Grid.Row="3" Margin="0,0,0,8">
                <TextBlock Text="Next Steps"
                           FontWeight="Bold"
                           FontSize="13"
                           Margin="0,0,0,6"/>
                <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           LineHeight="18"
                           TextWrapping="Wrap">
                    1.  Open Armoury Crate → Library → Manage Library (Add Game)<LineBreak/>
                    2.  Browse and select the generated launcher .exe<LineBreak/>
                    3.  (Optional) Add cover art manually if downloaded (path shown below)
                </TextBlock>
            </StackPanel>

            <!-- Cover art status -->
            <TextBlock x:Name="ArtworkStatusLabel"
                       Text=""
                       FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,16"
                       Grid.Row="4"/>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Grid.Row="5">
                <ui:Button Content="Open Launchers Folder"
                           Appearance="Primary"
                           Width="180"
                           Click="OpenFolder_Click"
                           Margin="0,0,12,0"/>
                <ui:Button Content="New Wrapper"
                           Appearance="Secondary"
                           Width="110"
                           Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
