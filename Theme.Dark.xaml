<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Palette -->
    <SolidColorBrush x:Key="WindowBgBrush"      Color="#1E1E1E"/>
    <SolidColorBrush x:Key="CardBgBrush"        Color="#2D2D2D"/>
    <SolidColorBrush x:Key="BorderBrush"        Color="#444444"/>
    <SolidColorBrush x:Key="TextBrush"          Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="#A0A0A0"/>
    <SolidColorBrush x:Key="AccentBrush"        Color="#4CA3E0"/>
    <SolidColorBrush x:Key="InputBgBrush"       Color="#3C3C3C"/>
    <SolidColorBrush x:Key="InputBorderBrush"   Color="#555555"/>
    <SolidColorBrush x:Key="ProgressTrackBrush" Color="#3A3A3A"/>

</ResourceDictionary>
