<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Structural / Non-Colour Styles =====
         Colour brushes (WindowBgBrush, CardBgBrush, etc.) are defined in
         Theme.Light.xaml / Theme.Dark.xaml and merged at runtime by ThemeManager. -->

    <!-- Base Window Style -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource WindowBgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Base Label Style -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- Card/Frame Style -->
    <Style x:Key="CardFrame" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <!-- Primary Button -->
    <Style TargetType="Button">
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="MinHeight" Value="24"/>
    </Style>

    <!-- Secondary Button -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Padding" Value="10,4"/>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Padding" Value="4,3"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}"/>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Padding" Value="4,3"/>
        <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    </Style>

    <!-- ProgressBar with accent-coloured fill that works in dark mode -->
    <Style TargetType="ProgressBar">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border CornerRadius="3"
                            Background="{DynamicResource ProgressTrackBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <!-- Determinate fill -->
                            <Rectangle x:Name="PART_Track" Fill="Transparent"/>
                            <Rectangle x:Name="PART_Indicator"
                                       HorizontalAlignment="Left"
                                       Fill="{DynamicResource AccentBrush}"
                                       RadiusX="3" RadiusY="3"/>
                            <!-- Indeterminate animation bar -->
                            <Rectangle x:Name="PART_GlowRect"
                                       Width="80"
                                       HorizontalAlignment="Left"
                                       Fill="{DynamicResource AccentBrush}"
                                       RadiusX="3" RadiusY="3"
                                       Opacity="0.85">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform x:Name="GlowTranslate" X="-80"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="GlowTranslate"
                                            Storyboard.TargetProperty="X"
                                            From="-80" To="420"
                                            Duration="0:0:1.4"
                                            AutoReverse="False"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsIndeterminate" Value="False">
                            <Setter TargetName="PART_GlowRect" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
