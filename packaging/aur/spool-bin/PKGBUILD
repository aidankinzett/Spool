# Maintainer: Aidan Kinzett <akinzett@gmail.com>
pkgname=spool-bin
_pkgname=spool
pkgver=0.1.0          # bump to match the released git tag (without the leading v)
pkgrel=1
pkgdesc="Game library + save-management wrapper (Tauri). Launches Windows games via Proton on Linux."
arch=('x86_64')
url="https://github.com/aidankinzett/Spool"
license=('MIT')
# Runtime libs for the Tauri/WebKitGTK app + the tools Spool drives.
# umu-launcher: run Windows games via Proton. ludusavi: save backup/restore.
# rclone: cloud save sync. webkit2gtk-4.1/gtk3/libayatana-appindicator: the app shell + tray.
depends=(
  'webkit2gtk-4.1'
  'gtk3'
  'libayatana-appindicator'
  'umu-launcher'
  'ludusavi'
  'rclone'
)
provides=('spool')
conflicts=('spool')
# The release tarball holds the raw binary + icon (PKGBUILD generates the .desktop).
source=("${_pkgname}-${pkgver}-x86_64.tar.gz::${url}/releases/download/v${pkgver}/${_pkgname}-${pkgver}-x86_64.tar.gz")
# Replace with the real checksum each release: `updpkgsums` (from pacman-contrib).
sha256sums=('SKIP')

package() {
  install -Dm755 "${srcdir}/spool" "${pkgdir}/usr/bin/spool"
  install -Dm644 "${srcdir}/spool.png" "${pkgdir}/usr/share/icons/hicolor/128x128/apps/spool.png"

  install -d "${pkgdir}/usr/share/applications"
  cat > "${pkgdir}/usr/share/applications/spool.desktop" <<'EOF'
[Desktop Entry]
Name=Spool
Comment=Game library + save-management wrapper
Exec=spool
Icon=spool
Terminal=false
Type=Application
Categories=Game;Utility;
StartupWMClass=Spool
EOF
}
