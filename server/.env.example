DATABASE_PATH=/data/spool.db
ADMIN_SECRET=changeme
PORT=47633

# ── Save storage (optional) ──────────────────────────────────────────────
# Public URL clients reach the WebDAV save store at (the spool-storage service).
# Leave blank to disable save storage. Use https:// in production.
WEBDAV_PUBLIC_URL=
# Shared secret guarding the internal rclone auth callback. Must match the
# spool-storage container. Make it strong.
WEBDAV_AUTH_SECRET=changeme
SAVES_DIR=/data/saves
