{
  "name": "spool-server",
  "version": "1.0.0",
  "description": "Cross-device play state lock server for Spool",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
