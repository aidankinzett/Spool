    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.7"
  }
}
