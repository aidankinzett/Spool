{
  "name": "spool",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "// workspaces": "Empty array — declares this package.json as a workspace root so bun stops walking up the directory tree when resolving install location. Without this, bun was creating a phantom workspace at .claude/worktrees/ because it saw sibling package.json files (tauri/, server/) and inferred a multi-project workspace.",
  "workspaces": [],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "svelte-kit sync && vitest run",
    "test:watch": "svelte-kit sync && vitest",
    "test:coverage": "svelte-kit sync && vitest run --coverage",
    "download-sidecars": "node scripts/download-sidecars.js",
    "e2e:build": "tauri build --no-bundle",
    "e2e": "wdio run ./wdio.conf.ts",
    "test:e2e": "bun run e2e:build && bun run e2e"
  },
  "license": "MIT",
  "dependencies": {
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@lucide/svelte": "^1.16.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@wdio/cli": "^9.20.0",
    "@wdio/globals": "^9.20.0",
    "@wdio/local-runner": "^9.20.0",
    "@wdio/mocha-framework": "^9.20.0",
    "@wdio/spec-reporter": "^9.20.0",
    "@wdio/types": "^9.20.0",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
