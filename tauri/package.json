{
  "name": "spool",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "// workspaces": "Empty array — declares this package.json as a workspace root so bun stops walking up the directory tree when resolving install location. Without this, bun was creating a phantom workspace at .claude/worktrees/ because it saw sibling package.json files (tauri/, server/) and inferred a multi-project workspace.",
  "workspaces": [],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "gen:steam-art": "bun run scripts/gen-steam-art.mjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "svelte-kit sync && vitest run --project unit",
    "test:watch": "svelte-kit sync && vitest --project unit",
    "test:coverage": "svelte-kit sync && vitest run --project unit --coverage",
    "test:storybook": "svelte-kit sync && vitest run --project storybook",
    "storybook": "svelte-kit sync && storybook dev -p 6006",
    "build-storybook": "svelte-kit sync && storybook build",
    "screenshots": "node scripts/screenshots.mjs",
    "download-sidecars": "node scripts/download-sidecars.js",
    "e2e:build": "tauri build --no-bundle",
    "e2e": "wdio run ./wdio.conf.ts",
    "test:e2e": "bun run e2e:build && bun run e2e",
    "build:appimage": "bash scripts/build-appimage.sh",
    "dev:link": "bash scripts/dev-link-appimage.sh",
    "dev:unlink": "bash scripts/dev-unlink-appimage.sh"
  },
  "license": "MIT",
  "dependencies": {
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@lucide/svelte": "^1.17.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/sveltekit": "^10.4.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.9.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "@wdio/cli": "^9.27.2",
    "@wdio/globals": "^9.27.2",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "@wdio/types": "^9.27.2",
    "eslint": "^10.4.1",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "storybook": "^10.4.2",
    "svelte": "^5.56.2",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wawoff2": "^2.0.1"
  }
}
