# Local dev secrets, loaded at build time by build.rs (see load_dotenv).
# Copy to `.env` (gitignored) and fill in. CI sets these as real env vars
# from repo secrets, so this file is only for local builds.
#
# Spool's Google Drive OAuth client. Without these, the OAuth flow falls back
# to rclone's shared default client (full `drive` scope). With them, Spool
# uses its own client and the narrower `drive.file` scope — set them to test
# the production cloud path locally. Read via option_env! in src/rclone.rs.
SPOOL_GDRIVE_CLIENT_ID=
SPOOL_GDRIVE_CLIENT_SECRET=
