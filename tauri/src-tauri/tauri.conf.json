{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spool",
  "version": "0.1.0",
  "identifier": "com.spool.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Spool",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$LOCALDATA/Spool/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "installationPath": "{LocalAppData}\\Programs\\Spool"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/aidankinzett/Spool/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlCRDVENTdFOEYxQ0EzNjQKUldSa294eVBmdFhWbTFCZ1lnVVlhYVZNaSthQUl4aEt5c1VTNnZRcXhsZVB6Rlc2L1I2ZGVoZVgK"
    }
  }
}
