<?xml version="1.0" encoding="utf-8"?>
<item>
    <!-- The version number of the latest available update. If this is higher than the Version defined in MainWindow.xaml.cs, the user will be prompted to update. -->
    <version>4.3.4</version>
    
    <!-- URL to the latest installer or executable file (typically hosted as a GitHub Release asset) -->
    <url>https://github.com/aidankinzett/Spool/releases/download/v4.3.4/spool-setup.exe</url>
    
    <!-- URL to the release changelog (or a markdown/HTML page summarizing the new features) -->
    <changelog>https://github.com/aidankinzett/Spool/releases/latest</changelog>
    
    <!-- If set to true, skips the Skip and Remind Later buttons and forces the update -->
    <mandatory>false</mandatory>
</item>
